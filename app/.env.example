# ── Compute engine (FastAPI / volcontrol) ───────────────────────────────────
# Base URL of the running Python engine. The Next.js server-side route handlers
# proxy to this; it is never exposed to the browser.
ENGINE_URL=http://localhost:8000

# ── AI explainer (server-side only) ─────────────────────────────────────────
# The OpenAI key lives ONLY on the server. The explainer is fed the already
# computed numbers and is constrained to explain them — it never recomputes.
# Leave empty to disable the explainer gracefully (the UI will say so).
OPENAI_API_KEY=
# Optional: override the model. Defaults to gpt-4o-mini.
OPENAI_MODEL=gpt-4o-mini
